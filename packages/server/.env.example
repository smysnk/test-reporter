# Package-local reference for server settings.
# Runtime env is still loaded from the repo root .env or .env.local.

SERVER_PORT=4400
# Optional. Defaults to http://localhost:${WEB_PORT} when omitted.
WEB_URL=http://localhost:3001
# Optional. Defaults to 50mb.
SERVER_JSON_LIMIT=50mb
# Optional. Defaults to SERVER_JSON_LIMIT when omitted.
INGEST_JSON_LIMIT=50mb
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/test_station
INGEST_SHARED_KEY=change-me
