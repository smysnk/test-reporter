# Package-local reference for web settings.
# Runtime env is still loaded from the repo root .env or .env.local.

WEB_PORT=3001
SERVER_PORT=4400
# Optional. Defaults to http://localhost:${SERVER_PORT} when omitted.
SERVER_URL=http://localhost:4400
# Optional. Defaults to /graphql when omitted.
# WEB_GRAPHQL_PATH=/graphql
# Optional. Defaults to http://localhost:${WEB_PORT} when omitted.
# NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=test-station-web-development-secret
WEB_DEFAULT_PROJECT_KEYS=*
WEB_ADMIN_EMAILS=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
