{
  "name": "@test-reporter/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "test-reporter": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "dependencies": {
    "@test-reporter/core": "workspace:*",
    "@test-reporter/render-html": "workspace:*"
  },
  "scripts": {
