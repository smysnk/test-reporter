# Copy to .env.fleet before applying the shared Fleet runtime secret.

DATABASE_URL=postgres://test-station:change-me@postgresql.default.svc.cluster.local:5432/test_station
# Match this with the GitHub Actions secret TEST_STATION_INGEST_SHARED_KEY when CI publishes to /api/ingest.
INGEST_SHARED_KEY=change-me
NEXTAUTH_SECRET=change-me
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
