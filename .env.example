# Copy the values you need into .env or .env.local at the repo root.
# config/env.mjs loads env from the repo root for both the server and web.

# Shared app URLs
SERVER_PORT=4400
WEB_PORT=3001
# Optional. Defaults to http://localhost:${SERVER_PORT} when omitted.
# SERVER_URL=http://localhost:4400
# Optional. Defaults to http://localhost:${WEB_PORT} when omitted.
# WEB_URL=http://localhost:3001
# Optional. Defaults to /graphql when omitted.
# WEB_GRAPHQL_PATH=/graphql

# Server database and ingest auth
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/test_station
INGEST_SHARED_KEY=change-me

# Web auth and access defaults
# Optional. Defaults to http://localhost:${WEB_PORT} when omitted.
# NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=test-station-web-development-secret
# Optional. Defaults to false. Ignored when Google OAuth is configured.
WEB_DEMO_AUTH_ENABLED=false
# Project visibility now comes from public visibility plus persisted role/group grants.
# Matching emails are also backfilled as durable admin users on server startup.
WEB_ADMIN_EMAILS=

# Optional SSO providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional artifact publishing to S3 for ingest metadata.
# Used by scripts/publish-ingest-report.mjs and the CI ingest publisher.
S3_BUCKET=
# Optional object prefix. CI defaults to ci/<repo>/<run_id>/<attempt> when omitted.
S3_STORAGE_PREFIX=
# Optional browser-facing base URL for uploaded artifacts, such as an S3 website,
# CloudFront distribution, or other CDN in front of the bucket.
S3_PUBLIC_URL=

# Optional AWS CLI credentials for local aws s3 sync usage.
# GitHub Actions uses S3_AWS_* secrets and vars instead.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
