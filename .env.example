# Copy the values you need into .env or .env.local at the repo root.
# config/env.mjs loads env from the repo root for both the server and portal.

# Shared app URLs
SERVER_PORT=4400
PORTAL_PORT=3001
SERVER_URL=http://localhost:4400
PORTAL_URL=http://localhost:3001
PORTAL_GRAPHQL_PATH=/graphql

# Server database and ingest auth
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/test_station
INGEST_API_KEYS=local-dev-shared-key
INGEST_SHARED_KEY=

# Portal auth and access defaults
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=test-station-portal-development-secret
PORTAL_DEFAULT_PROJECT_KEYS=*
PORTAL_ADMIN_EMAILS=

# Optional SSO providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
