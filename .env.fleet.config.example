# Optional shared runtime ConfigMap values.
# These are only used if fleet/gitrepo.yml sets server.existingConfigMap and web.existingConfigMap.

NODE_ENV=production
SERVER_PORT=4400
WEB_PORT=3001
WEB_GRAPHQL_PATH=/graphql
GA_MEASUREMENT_ID=
SERVER_URL=http://test-station-server:4400
WEB_URL=https://test-station.smysnk.com
NEXTAUTH_URL=https://test-station.smysnk.com
WEB_DEMO_AUTH_ENABLED=false
WEB_DEFAULT_PROJECT_KEYS=*
WEB_ADMIN_EMAILS=
