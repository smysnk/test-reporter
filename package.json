{
  "name": "test-station",
  "type": "module",
  "bin": "./bin/test-station.mjs",
  "exports": {
    "./config": "./config.mjs",
    "./bin": "./bin/test-station.mjs"
  },
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "mono-helper env yarn workspaces foreach -A --include server --include web -pi -j unlimited run dev",
    "build": "yarn workspaces foreach -A run build",
    "lint": "yarn workspaces foreach -A run lint",
    "test:node": "node --test ./tests/*.test.js",
    "test": "node ./bin/test-station.mjs run --config ./test-station.config.mjs",
    "test:coverage": "node ./bin/test-station.mjs run --config ./test-station.config.mjs --coverage",
    "test:e2e:performance": "playwright test -c ./playwright.performance.config.mjs",
    "test:e2e:performance:list": "playwright test -c ./playwright.performance.config.mjs --list",
    "pages:build": "node ./scripts/pages/build-self-test-site.mjs",
    "server:dev": "yarn workspace server dev",
    "server:start": "yarn workspace server start",
    "server:build": "yarn workspace server build",
    "server:lint": "yarn workspace server lint",
    "web:dev": "yarn workspace web dev",
    "web:start": "yarn workspace web start",
    "web:build": "yarn workspace web build",
    "web:lint": "yarn workspace web lint",
    "check": "yarn lint && yarn test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
